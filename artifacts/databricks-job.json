{
  "name": "Metadata-Driven-Ingestion",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "create_sample_data",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/armandoleonet95pp@gmail.com/ingestion-poc/01_create_sample_data",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "Job_cluster",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "create_metadata",
      "depends_on": [
        {
          "task_key": "create_sample_data"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/armandoleonet95pp@gmail.com/ingestion-poc/02_create_metadata",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "Job_cluster",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "ingestion_pipeline",
      "depends_on": [
        {
          "task_key": "create_metadata"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/armandoleonet95pp@gmail.com/ingestion-poc/03_ingestion_framework",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "Job_cluster",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "data_hub_load",
      "depends_on": [
        {
          "task_key": "ingestion_pipeline"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/armandoleonet95pp@gmail.com/ingestion-poc/04_datahub_load",
        "source": "WORKSPACE"
      },
      "job_cluster_key": "Job_cluster",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "Job_cluster",
      "new_cluster": {
        "spark_version": "17.3.x-scala2.13",
        "azure_attributes": {
          "first_on_demand": 1,
          "spot_bid_max_price": -1
        },
        "node_type_id": "Standard_D4ds_v4",
        "spark_env_vars": {
          "PYSPARK_PYTHON": "/databricks/python3/bin/python3"
        },
        "enable_elastic_disk": true,
        "data_security_mode": "LEGACY_SINGLE_USER_STANDARD",
        "runtime_engine": "PHOTON",
        "kind": "CLASSIC_PREVIEW",
        "is_single_node": true
      }
    }
  ],
  "queue": {
    "enabled": true
  }
}